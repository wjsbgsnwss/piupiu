# PiuPiu — copy to .env and fill in your values

# Debug mode: show all redactions, AI payloads, and pipeline traces (default: false)
# Set to true to troubleshoot; leave false in production (only errors are shown)
PIUPIU_DEBUG=false

# Master passphrase for graph encryption (required)
PIUPIU_PASSPHRASE=change-me-to-a-strong-passphrase

# Active channel: cli | telegram
PIUPIU_CHANNEL=cli

# Directory for encrypted graph and vault files
PIUPIU_DATA_DIR=.piupiu

# ── AI provider: anthropic | nim ──────────────────────
PIUPIU_AI_PROVIDER=anthropic

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...
PIUPIU_AI_MODEL=claude-sonnet-4-6

# NVIDIA NIM  (set PIUPIU_AI_PROVIDER=nim to use)
NIM_API_KEY=nvapi-...
PIUPIU_NIM_MODEL=meta/llama-3.1-70b-instruct
PIUPIU_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Telegram ──────────────────────────────────────────
# Required when PIUPIU_CHANNEL=telegram
TELEGRAM_BOT_TOKEN=

# ── Confirmation timeout ──────────────────────────────
# Seconds to wait for Accept/Reject before auto-accepting (0 = disabled)
PIUPIU_CONFIRM_TIMEOUT=10

# ── Web UI (optional) ─────────────────────────────────
# Requires: pip install 'piupiu[web]'
# Opens a graph browser at http://127.0.0.1:8080
PIUPIU_WEB_ENABLED=false
PIUPIU_WEB_HOST=127.0.0.1
PIUPIU_WEB_PORT=8080

# ── Ollama privacy shield layer (optional) ────────────
# When enabled, Ollama runs a final local check on the
# already-redacted text before it is sent to the cloud AI.
PIUPIU_OLLAMA_ENABLED=false
PIUPIU_OLLAMA_BASE_URL=http://localhost:11434
PIUPIU_OLLAMA_MODEL=qwen2.5:3b
PIUPIU_OLLAMA_TIMEOUT=30
